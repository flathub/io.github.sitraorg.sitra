{
    "id": "io.github.sitraorg.sitra",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "sitra",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--filesystem=~/.local/share/fonts:create"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/gir-1.0",
        "/share/vala"
    ],
    "modules": [
        {
            "name": "libsitra",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/sitraorg/libsitra.git",
                    "tag": "v0.1.0",
                    "commit": "d804cb7aa3030dc32a951b2dd2eb11aa330e2601"
                }
            ]
        },
        {
            "name": "sitra",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/sitraorg/sitra.git",
                    "tag": "v0.1.2",
                    "commit": "7f393ffbb4e3dd82c01f256c5768b5430f2f02b9"
                }
            ]
        }
    ]
}
